POSTGRES_DB=infinitemail
POSTGRES_USER=infinitemail
POSTGRES_PASSWORD=change-this-postgres-password

USER_APP_ORIGIN=https://mail.example.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_PASSWORD_HASH=argon2id-password-hash
ADMIN_API_TOKEN=
MAIL_WEBHOOK_TOKEN=change-this-webhook-token
MAILBOX_CREDENTIAL_KEY=change-this-long-random-mailbox-credential-key

STALWART_IMAGE=stalwartlabs/stalwart:v0.16
STALWART_PUBLIC_URL=https://mail.example.com
STALWART_ADMIN_URL=http://stalwart:8080
STALWART_RECOVERY_ADMIN=admin:change-this-stalwart-password

INFINITEMAIL_PRODUCTION_STRICT=true
REQUIRE_REAL_SMS=true
REQUIRE_REAL_OAUTH=true
REQUIRE_MAIL_DATA_PLANE=true
REQUIRE_MAIL_WEBHOOK=true
